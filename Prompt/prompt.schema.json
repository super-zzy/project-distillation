{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PromptConfig",
  "type": "object",
  "required": ["id", "name", "version", "model", "system_prompt", "user_template", "variables", "output_schema"],
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "name": { "type": "string", "minLength": 3 },
    "version": { "type": "string", "pattern": "^v\\d+(\\.\\d+)?$" },
    "model": { "type": "string" },
    "system_prompt": { "type": "string", "minLength": 10 },
    "user_template": { "type": "string", "minLength": 10 },
    "variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "required"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["string", "number", "boolean", "json"] },
          "required": { "type": "boolean" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "output_schema": {
      "type": "object",
      "description": "JSON schema that model output must satisfy.",
      "required": ["type", "required", "properties"],
      "additionalProperties": true
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}

